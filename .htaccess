# Tirana Solidare — Apache Configuration

# Custom error pages
ErrorDocument 404 /TiranaSolidare/views/404.php

# Prevent directory listing
Options -Indexes

# Deny access to sensitive files
<FilesMatch "\.(sql|md|env|log)$">
    Require all denied
</FilesMatch>

# Block direct web access to CLI-only scripts (migrations, seeds, dev tools)
<FilesMatch "^(migrate_|cleanup_|seed_|generate_)">
    Require all denied
</FilesMatch>

# Block web access to the entire migrations/ directory
<IfModule mod_rewrite.c>
    RewriteRule ^migrations/ - [F,L]
</IfModule>

# Protect config directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
</IfModule>
