# Database Configuration
DB_HOST=localhost
# Port: XAMPP uses 3307; most Linux/production servers use 3306
DB_PORT=3306
DB_NAME=TiranaSolidare
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@tiranasolidare.al
SMTP_FROM_NAME=Tirana Solidare

# Application — set to your server's full base URL (no trailing slash)
# Local XAMPP: http://localhost/TiranaSolidare
# Production:  https://yourdomain.com/TiranaSolidare  (or just https://yourdomain.com if deployed at root)
APP_URL=https://yourdomain.com/TiranaSolidare
APP_TIMEZONE=Europe/Tirane

# Web Push (VAPID) — generate with: php generate_vapid.php
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
